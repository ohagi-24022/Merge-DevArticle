# TiDB Serverless — TiDB Cloud console → Connect → General
# Example: mysql://<user>.<prefix>:<password>@gatewayXX.region.prod.aws.tidbcloud.com:4000/<database>
DATABASE_URL=
# TLS is enabled automatically for *.tidbcloud.com hosts; set true for other TLS MySQL hosts
# DATABASE_SSL=true

# Session signing (generate a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub numeric user id for admin role (https://api.github.com/users/<username>)
OWNER_GITHUB_ID=

# OpenAI (article generation)
OPENAI_API_KEY=
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Object storage (S3-compatible: AWS S3, Cloudflare R2, etc.)
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# Google Maps (optional)
GOOGLE_MAPS_API_KEY=

# Optional webhook for admin notifications
# NOTIFY_WEBHOOK_URL=

# Scheduled HTTP jobs — Fly Machines cron / external scheduler
# CRON_SECRET=

# Frontend (Vite)
VITE_APP_TITLE=サークル開発記録掲示板
# VITE_GOOGLE_MAPS_API_KEY=
